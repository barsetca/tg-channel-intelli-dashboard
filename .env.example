# --- Shared ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# SQLite (path relative to backend working dir)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Telegram (Telethon) — учётные данные с https://my.telegram.org → API development tools (не BotFather).
# TELEGRAM_API_ID — число api_id; TELEGRAM_API_HASH — строка api_hash; не коммитьте в git.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# StringSession (строка из Telethon после client.session.save()). Имеет приоритет над файлом; можно ротировать в рантайме.
# TELEGRAM_SESSION=
# Имя файла сессии Telethon на диске (например telegram_session.session после первого входа), если TELEGRAM_SESSION пуст.
TELEGRAM_SESSION_NAME=telegram_session
# Каталог для *.session (относительно рабочей директории backend или абсолютный путь).
TELEGRAM_SESSION_DIR=data/sessions
# Повтор при FloodWait: максимум секунд ожидания за один запрос Telegram и число доп. попыток.
TELEGRAM_FLOOD_MAX_WAIT_SECONDS=60
TELEGRAM_FLOOD_RETRY_ATTEMPTS=2
# Разрешить первый вход через API (телефон → код → 2FA). В production часто false.
TELEGRAM_INTERACTIVE_LOGIN=true

# OpenAI — embeddings + LLM
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# OpenAI Images — генерация иллюстраций и инфографики (модуль «Публикация»)
# dall-e-3 (по умолчанию) или gpt-image-1 / gpt-image-1-mini
OPENAI_IMAGE_MODEL=dall-e-3
# DALL·E 3: 1024x1024 | 1792x1024 | 1024x1792
# gpt-image-1: 1024x1024 | 1536x1024 | 1024x1536 | auto (1792×* из .env маппится автоматически)
OPENAI_IMAGE_SIZE=1024x1024
# DALL·E 3: standard | hd
# gpt-image-1: low | medium | high | auto
OPENAI_IMAGE_QUALITY=standard
# Образцы стиля автора для AI-постов. Пусто — context/post_style.txt или bundled в backend.
# PUBLISHING_STYLE_PATH=context/post_style.txt

# Qdrant — vector store
# QDRANT_URL: из хоста к контейнеру — localhost:6333; из контейнера api к qdrant — http://qdrant:6333
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY: секрет HTTP API (нужен для Qdrant Cloud / защищённого инстанса). Локальный образ из compose — оставьте пустым.
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=channel_messages

# --- Frontend (Next.js) ---
# Browser / client-side requests
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server-side (Docker Compose): use service DNS
# API_URL=http://api:8000
